# ── User-provided keys (take priority over Aretica shared keys) ──────────────
# Leave blank to use Aretica's shared keys (set at build time)
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
OPENAI_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── Aretica shared keys (baked in at build time for distribution) ─────────────
# Set these when building the .dmg — users get zero-config Axon out of the box
ARETICA_ANTHROPIC_KEY=
ARETICA_ELEVENLABS_KEY=
ARETICA_OPENAI_KEY=
ARETICA_SUPABASE_URL=
ARETICA_SUPABASE_ANON_KEY=

# ── Optional configuration ────────────────────────────────────────────────────
AXON_WAKE_WORD=
DEVICE_ROLE=
OBSIDIAN_VAULT_PATH=
AXON_ENCRYPT_MEMORY=
AXON_ENCRYPTION_KEY=
