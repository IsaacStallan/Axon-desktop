{
  "name": "axon-desktop",
  "version": "1.0.24-beta",
  "description": "Axon — ambient AI presence for Windows",
  "main": ".webpack/main",
  "scripts": {
    "start": "electron-forge start",
    "build": "electron-forge make",
    "make": "electron-forge make",
    "package": "electron-forge package",
    "publish": "electron-forge publish",
    "deploy": "wrangler deploy",
    "preview": "wrangler dev",
    "generate-training-data": "ts-node --transpile-only scripts/generate_training_data.ts",
    "import-model": "bash scripts/import_model.sh",
    "setup-mdm": "bash scripts/setup_mdm.sh",
    "start-mdm-server": "ts-node --transpile-only src/services/mdmServer.ts",
    "release": "bash scripts/release.sh",
    "inject-env": "node scripts/inject-env.js",
    "prebuild": "node scripts/inject-env.js",
    "prepackage": "node scripts/inject-env.js"
  },
  "build": {
    "publish": {
      "provider": "github",
      "owner": "IsaacStallan",
      "repo": "Axon-desktop"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "keywords": [],
  "author": "Isaac",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@supabase/supabase-js": "^2.49.4",
    "axios": "^1.9.0",
    "dotenv": "^16.5.0",
    "electron-updater": "^6.8.3",
    "elevenlabs": "^1.57.0",
    "openai": "^6.32.0",
    "play-sound": "^1.1.6",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.0",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.8.0",
    "@electron-forge/maker-zip": "^7.8.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.0",
    "@electron-forge/plugin-webpack": "^7.8.0",
    "@electron-forge/publisher-github": "^7.11.1",
    "@types/node": "^22.15.3",
    "@types/play-sound": "^1.1.2",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "copy-webpack-plugin": "^13.0.0",
    "electron": "^35.2.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "wrangler": "^4.84.0"
  }
}
